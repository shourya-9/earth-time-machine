# Copy this file to `.streamlit/secrets.toml` for local testing,
# or paste its contents into Streamlit Community Cloud's
# "Advanced settings → Secrets" box before deploying.
#
# `.streamlit/secrets.toml` is gitignored — never commit it.

# Earth Engine project (the GCP project your service account lives in).
EARTHENGINE_PROJECT = "your-gcp-project-id"

# NASA FIRMS MAP_KEY for the fire overlay. Free at:
# https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY = "your-nasa-firms-map-key-here"

# Service account JSON key — paste the ENTIRE contents of the JSON file
# you downloaded from GCP under this section. Note:
#   - `private_key` must keep the literal "\n" newlines as shown.
#   - Every field that GCP's JSON file contains must be present here.
[GCP_SERVICE_ACCOUNT_JSON]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "0000000000000000000000000000000000000000"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIEv...REPLACE_ME...==\n-----END PRIVATE KEY-----\n"
client_email = "your-sa-name@your-gcp-project-id.iam.gserviceaccount.com"
client_id = "000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/your-sa-name%40your-gcp-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
